---
import Layout from '../layouts/Layout.astro';

const features = [
  { title: 'HTTP & REST', desc: 'Send GET, POST, PUT, PATCH, DELETE requests with full header, param, and body editors. Variable interpolation via {{mustache}}.' },
  { title: 'GraphQL', desc: 'Write queries in the Monaco-powered editor, auto-detect operation type, inspect response data and errors.' },
  { title: 'WebSocket', desc: 'Real-time WebSocket client with connection management, message history, and sub-protocol support.' },
  { title: 'gRPC-Web', desc: 'gRPC-Web JSON protocol support. Load .proto files to discover services and methods.' },
  { title: 'OAuth2 & JWT', desc: 'OAuth2 Authorization Code + PKCE flow, JWT HS256/RS256 sign/verify. Built-in Bearer, Basic, API Key auth.' },
  { title: 'Scripting & Tests', desc: 'Write test assertions in Rust. 7 assertion types: status, latency, body, header, JSON path, regex, content-type.' },
  { title: 'Workspaces & Envs', desc: 'File-based YAML collections. Multiple environments with variable overrides. Git-friendly format.' },
  { title: 'Import & Export', desc: 'Postman v2.1, cURL, Insomnia v4, Bruno .bru imports. Export as cURL, fetch, axios, Python, Go, Ruby, PowerShell, Java.' },
  { title: 'Plugin System', desc: 'WASM-based plugins sandboxed by wasmtime. Intercept requests/responses, custom logic, community marketplace.' },
  { title: 'Collaboration', desc: 'Yjs CRDT sync with live cursors and presence awareness. Real-time multi-device editing.' },
  { title: 'Dark Theme', desc: 'Light/dark/system themes. Monaco editor with syntax highlighting for JSON, XML, GraphQL, and more.' },
  { title: 'Open Source', desc: 'MIT-licensed. Rust core + Tauri desktop + web. No account required. Self-host or use cloud.' },
]
const tier = (idx: number) => {
  if (idx < 4) return 'badge-green'
  if (idx < 8) return 'badge-blue'
  return 'badge-yellow'
}
const mark = (idx: number) => {
  if (idx < 4) return 'Core' as const
  if (idx < 8) return 'Power' as const
  return 'Edge' as const
}
---
<Layout>
  <section class="hero-section container">
    <h1>
      Ship APIs faster with<br />
      <span class="highlight">ReqForge</span>
    </h1>
    <p>
      An open-source API development platform. Build, test, debug, document,
      and collaborate on HTTP, GraphQL, WebSocket, and gRPC-Web requests.
      No account required.
    </p>
    <div class="hero-buttons">
      <a href={`${import.meta.env.BASE_URL}docs/getting-started`} class="btn btn-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download
      </a>
      <a href="https://github.com/reqforge/reqforge" class="btn btn-secondary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>
  </section>

  <section id="features" class="container">
    <h2 class="section-title">Everything you need</h2>
    <p class="section-subtitle">From raw HTTP to real-time collaboration — ReqForge covers the full API lifecycle.</p>
    <div class="features-grid">
      {features.map((f, i) => (
        <div class="feature-card">
          <span class={`badge ${tier(i)}`} style="margin-bottom: 0.75rem; display: inline-block">{mark(i)}</span>
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="download" class="container" style="padding: 4rem 0; text-align: center;">
    <h2 class="section-title">Download</h2>
    <p class="section-subtitle">Available for Windows, macOS, and Linux.</p>
    <table class="download-table">
      <tr><th>Platform</th><th>Architecture</th><th>Download</th></tr>
      <tr><td>Windows</td><td>x86_64</td><td><a href="https://github.com/reqforge/reqforge/releases/latest/download/reqforge-x86_64-pc-windows-msvc.zip">.zip</a></td></tr>
      <tr><td>macOS</td><td>x86_64 &amp; arm64</td><td><a href="https://github.com/reqforge/reqforge/releases/latest/download/reqforge-x86_64-apple-darwin.tar.gz">Intel</a> · <a href="https://github.com/reqforge/reqforge/releases/latest/download/reqforge-aarch64-apple-darwin.tar.gz">Apple Silicon</a></td></tr>
      <tr><td>Linux</td><td>x86_64</td><td><a href="https://github.com/reqforge/reqforge/releases/latest/download/reqforge-x86_64-unknown-linux-gnu.tar.xz">.tar.xz</a></td></tr>
    </table>
    <p style="margin-top: 1rem; font-size: 0.875rem; color: var(--color-text-muted);">Visit the <a href="https://github.com/reqforge/reqforge/releases">releases page</a> for all versions.</p>
  </section>

  <section class="container" style="padding: 4rem 0; text-align: center;">
    <h2 class="section-title">Built with Rust, powered by Tauri</h2>
    <p class="section-subtitle" style="max-width: 600px; margin: 0 auto;">
      A shared Rust core library drives both the desktop app and the CLI.
      No Electron overhead — the binary is under 10 MB and uses under 100 MB
      of RAM even with heavy collections loaded.
    </p>
    <div class="hero-buttons" style="margin-top: 2rem;">
      <a href={`${import.meta.env.BASE_URL}docs`} class="btn btn-primary">Read the Docs</a>
      <a href={`${import.meta.env.BASE_URL}docs/getting-started`} class="btn btn-secondary">Get Started</a>
    </div>
  </section>
</Layout>
