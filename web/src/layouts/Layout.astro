---
export interface Props {
  title?: string
  description?: string
}
const {
  title = 'ReqForge — Ultimate API Development Platform',
  description = 'A modern, blazing-fast API client for HTTP, GraphQL, WebSocket, and more. Built with Rust, powered by Tauri.',
} = Astro.props
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      :root {
        --color-bg: #0f1117;
        --color-surface: #1a1c25;
        --color-border: #2a2d3a;
        --color-text: #e2e4eb;
        --color-text-muted: #8b8fa3;
        --color-primary: #4f8cff;
        --color-primary-hover: #6ba1ff;
        --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--font-sans);
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--color-primary); text-decoration: none; }
      a:hover { color: var(--color-primary-hover); }
      pre, code { font-family: var(--font-mono); }
      .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
      nav {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1rem 1.5rem; border-bottom: 1px solid var(--color-border);
        background: var(--color-bg); position: sticky; top: 0; z-index: 100;
      }
      nav .logo { font-size: 1.25rem; font-weight: 700; color: var(--color-text); }
      nav .logo span { color: var(--color-primary); }
      nav .nav-links { display: flex; gap: 2rem; align-items: center; }
      nav .nav-links a { color: var(--color-text-muted); font-size: 0.875rem; font-weight: 500; }
      nav .nav-links a:hover { color: var(--color-text); }
      nav .cta { background: var(--color-primary); color: #fff; padding: 0.5rem 1.25rem; border-radius: 8px; font-size: 0.875rem; font-weight: 600; }
      nav .cta:hover { background: var(--color-primary-hover); }
      footer { border-top: 1px solid var(--color-border); padding: 3rem 1.5rem; margin-top: 6rem; text-align: center; color: var(--color-text-muted); font-size: 0.875rem; }
      footer .links { display: flex; gap: 2rem; justify-content: center; margin-bottom: 1rem; }
      footer .links a { color: var(--color-text-muted); }
      footer .links a:hover { color: var(--color-text); }
      .hero-section { padding: 6rem 0; text-align: center; }
      .hero-section h1 { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 800; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 1.5rem; }
      .hero-section h1 .highlight { color: var(--color-primary); }
      .hero-section p { font-size: 1.125rem; color: var(--color-text-muted); max-width: 640px; margin: 0 auto 2.5rem; }
      .hero-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
      .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.75rem; border-radius: 10px; font-size: 0.9375rem; font-weight: 600; border: none; cursor: pointer; }
      .btn-primary { background: var(--color-primary); color: #fff; }
      .btn-secondary { background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border); }
      .features-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; padding: 4rem 0; }
      .feature-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 12px; padding: 1.75rem; }
      .feature-card h3 { font-size: 1.125rem; margin-bottom: 0.5rem; }
      .feature-card p { font-size: 0.875rem; color: var(--color-text-muted); }
      .section-title { text-align: center; font-size: 2rem; font-weight: 700; margin-bottom: 0.75rem; }
      .section-subtitle { text-align: center; color: var(--color-text-muted); font-size: 1rem; margin-bottom: 2rem; }
      .badge { display: inline-block; padding: 0.125rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; font-family: var(--font-mono); }
      .badge-green { background: rgba(74, 222, 128, 0.15); color: #4ade80; }
      .badge-blue { background: rgba(79, 140, 255, 0.15); color: var(--color-primary); }
      .badge-yellow { background: rgba(250, 204, 21, 0.15); color: #facc15; }
      .doc-sidebar { width: 240px; flex-shrink: 0; }
      .doc-sidebar h4 { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); margin: 1.5rem 0 0.5rem; }
      .doc-sidebar a { display: block; padding: 0.375rem 0; font-size: 0.875rem; color: var(--color-text-muted); }
      .doc-sidebar a:hover, .doc-sidebar a.active { color: var(--color-text); }
      .doc-content { flex: 1; min-width: 0; padding: 2rem 0; }
      .doc-content h1 { font-size: 2rem; margin-bottom: 1rem; }
      .doc-content h2 { font-size: 1.5rem; margin: 2rem 0 0.75rem; }
      .doc-content p { margin-bottom: 1rem; color: var(--color-text-muted); }
      .doc-content pre { background: var(--color-surface); padding: 1rem; border-radius: 8px; overflow-x: auto; margin: 1rem 0; font-size: 0.875rem; }
      .doc-content code { font-size: 0.875em; }
      .doc-content ul { margin: 1rem 0; padding-left: 1.5rem; color: var(--color-text-muted); }
      .doc-content li { margin-bottom: 0.5rem; }
      @media (max-width: 768px) { nav .nav-links { display: none; } .features-grid { grid-template-columns: 1fr; } }
      @media (max-width: 768px) {
        .doc-layout { flex-direction: column; }
        .doc-sidebar { width: 100%; }
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="logo">Req<span>Forge</span></a>
      <div class="nav-links">
        <a href="/#features">Features</a>
        <a href="/docs">Docs</a>
        <a href="/docs/getting-started">Getting Started</a>
        <a href="https://github.com/reqforge/reqforge">GitHub</a>
        <a href="/docs" class="cta">Download</a>
      </div>
    </nav>
    <main><slot /></main>
    <footer>
      <div class="links">
        <a href="/">Home</a>
        <a href="/docs">Docs</a>
        <a href="https://github.com/reqforge/reqforge">GitHub</a>
        <a href="https://discord.gg/reqforge">Discord</a>
      </div>
      <p>&copy; {new Date().getFullYear()} ReqForge. MIT license.</p>
    </footer>
  </body>
</html>
