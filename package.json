{
  "name": "reqforge",
  "version": "0.1.0",
  "private": true,
  "description": "ReqForge - Ultimate API Development Platform",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "tauri:dev": "pnpm --filter @reqforge/desktop tauri dev",
    "tauri:build": "pnpm --filter @reqforge/desktop tauri build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@11.13.0",
  "pnpm": {
    "overrides": {
      "dompurify@>=3.1.3 <=3.3.1": ">=3.3.2",
      "dompurify@<=3.3.1": ">=3.3.2",
      "dompurify@<=3.3.3": ">=3.4.0",
      "dompurify@<3.4.0": ">=3.4.0",
      "dompurify@>=1.0.10 <3.4.0": ">=3.4.0",
      "dompurify@>=3.0.1 <3.4.0": ">=3.4.0",
      "dompurify@<3.3.2": ">=3.3.2",
      "dompurify@<3.4.7": ">=3.4.7",
      "dompurify@<=3.4.5": ">=3.4.6",
      "dompurify@<3.4.9": ">=3.4.9",
      "dompurify@>=3.0.0 <=3.4.7": ">=3.4.8",
      "dompurify@<=3.4.6": ">=3.4.7",
      "dompurify@<=3.4.10": ">=3.4.11"
    }
  }
}
