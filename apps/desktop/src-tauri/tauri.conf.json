{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "ReqForge",
  "version": "0.1.0",
  "identifier": "dev.reqforge.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ReqForge",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Ultimate API Development Platform",
    "longDescription": "A modern, blazing-fast API client for HTTP, GraphQL, WebSocket, and more."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/reqforge/reqforge/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_PUBLIC_KEY_FROM_TAURI_KEYGEN",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
